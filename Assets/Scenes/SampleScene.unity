--- !u!114 &8175821890271877597
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 3176696765395993175}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "T\u1EBF b\xE0o ch\u1EA5t"
  description: "Bao g\u1ED3m d\u1ECBch b\xE0o (cytosol) v\xE0 c\xE1c b\xE0o quan,
    \u0111\xF3ng vai tr\xF2 l\xE0 m\xF4i tr\u01B0\u1EDDng cho c\xE1c ph\u1EA3n \u1EE9ng
    sinh h\xF3a v\xE0 qu\xE1 tr\xECnh v\u1EADn chuy\u1EC3n n\u1ED9i b\xE0o. Th\xE0nh
    ph\u1EA7n n\xE0y chi\u1EBFm ph\u1EA7n l\u1EDBn th\u1EC3 t\xEDch c\u1EE7a t\u1EBF
    b\xE0o, tuy t\u1EF7 l\u1EC7 c\xF3 th\u1EC3 thay \u0111\u1ED5i t\xF9y theo t\u1EEBng
    lo\u1EA1i t\u1EBF b\xE0o. V\u1EC1 c\u1EA5u tr\xFAc, t\u1EBF b\xE0o ch\u1EA5t
    c\xF3 d\u1EA1ng m\xF4i tr\u01B0\u1EDDng keo (gel), ch\u1EE9a n\u01B0\u1EDBc,
    ion, c\xE1c ph\xE2n t\u1EED h\xF2a tan, ribosome v\xE0 h\u1EA7u h\u1EBFt c\xE1c
    b\xE0o quan (tr\u1EEB nh\xE2n). B\xEAn trong c\xF2n c\xF3 h\u1EC7 th\u1ED1ng
    b\u1ED9 khung t\u1EBF b\xE0o (cytoskeleton) g\u1ED3m vi \u1ED1ng (microtubules),
    vi s\u1EE3i (microfilaments) v\xE0 s\u1EE3i trung gian, gi\xFAp duy tr\xEC h\xECnh
    d\u1EA1ng v\xE0 t\u1ED5 ch\u1EE9c kh\xF4ng gian c\u1EE7a t\u1EBF b\xE0o. Nh\u1EDD
    v\u1EADy, t\u1EBF b\xE0o ch\u1EA5t l\xE0 n\u01A1i di\u1EC5n ra c\xE1c ph\u1EA3n
    \u1EE9ng chuy\u1EC3n h\xF3a quan tr\u1ECDng, \u0111\u1ED3ng th\u1EDDi h\u1ED7
    tr\u1EE3 s\u1EF1 di chuy\u1EC3n c\u1EE7a b\xE0o quan v\xE0 t\u1EA1o n\u1EC1n
    t\u1EA3ng cho c\xE1c ho\u1EA1t \u0111\u1ED9ng sinh h\u1ECDc trong t\u1EBF b\xE0o.\r"
  pathType: 1
  partId: 10
  icon: {fileID: 21300000, guid: 12040525e0ca28148adaf65cde7e4d2d, type: 3}
  isValid: 1
  spacing: 1
  sortFromTop: 1
  startYOffset: 0
  blinkChildren: 0
  blinkChildList: []
  blinkColor: {r: 1, g: 0.92156863, b: 0.015686275, a: 1}
  blinkSpeed: 2
  blinkIntensity: 1.5
