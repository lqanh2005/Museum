--- !u!114 &7572776377553666701
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2093417753040386328}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "B\u1ED9 m\xE1y Golgi"
  description: "L\xE0 b\xE0o quan g\u1ED3m nhi\u1EC1u t\xFAi d\u1EB9t x\u1EBFp ch\u1ED3ng
    l\xEAn nhau, c\xF3 ch\u1EE9c n\u0103ng ch\u1EC9nh s\u1EEDa, ph\xE2n lo\u1EA1i,
    \u0111\xF3ng g\xF3i v\xE0 v\u1EADn chuy\u1EC3n protein c\u0169ng nh\u01B0 lipid
    trong t\u1EBF b\xE0o. C\u1EA5u tr\xFAc c\u1EE7a Golgi g\u1ED3m c\xE1c cisternae
    (nh\u1EEFng t\xFAi m\xE0ng d\u1EB9t) x\u1EBFp th\xE0nh t\u1EEBng b\xF3, v\u1EDBi
    \u0111\u1ED9 d\xE0y kho\u1EA3ng 10\u201320 nm v\xE0 \u0111\u01B0\u1EDDng k\xEDnh
    m\u1ED7i cisterna v\xE0o kho\u1EA3ng 0,5\u20131,0 \xB5m t\xF9y lo\u1EA1i t\u1EBF
    b\xE0o; s\u1ED1 l\u01B0\u1EE3ng cisternae trong m\u1ED7i b\xF3 c\u0169ng c\xF3
    th\u1EC3 thay \u0111\u1ED5i. B\u1ED9 m\xE1y Golgi c\xF3 hai m\u1EB7t ch\xEDnh
    l\xE0 m\u1EB7t cis (nh\u1EADn c\xE1c s\u1EA3n ph\u1EA9m t\u1EEB l\u01B0\u1EDBi
    n\u1ED9i ch\u1EA5t) v\xE0 m\u1EB7t trans (xu\u1EA5t c\xE1c s\u1EA3n ph\u1EA9m
    ra ngo\xE0i t\u1EBF b\xE0o ho\u1EB7c \u0111\u1EBFn c\xE1c b\xE0o quan kh\xE1c
    nh\u01B0 lysosome). T\u1EA1i \u0111\xE2y, protein v\xE0 lipid \u0111\u01B0\u1EE3c
    bi\u1EBFn \u0111\u1ED5i th\xF4ng qua c\xE1c qu\xE1 tr\xECnh nh\u01B0 glycosyl
    h\xF3a hay phosphoryl h\xF3a, sau \u0111\xF3 \u0111\u01B0\u1EE3c ph\xE2n lo\u1EA1i
    v\xE0 \u0111\xF3ng g\xF3i v\xE0o c\xE1c t\xFAi v\u1EADn chuy\u1EC3n \u0111\u1EC3
    \u0111\u01B0a \u0111\u1EBFn m\xE0ng t\u1EBF b\xE0o, lysosome ho\u1EB7c ti\u1EBFt
    ra ngo\xE0i. Ngo\xE0i ra, Golgi c\xF2n tham gia t\u1EA1o lysosome d\u01B0\u1EDBi
    d\u1EA1ng c\xE1c t\xFAi ch\u1EE9a enzyme ti\xEAu h\xF3a."
  pathType: 1
  partId: 9
  icon: {fileID: 21300000, guid: 3a6937621f0d436418ac4ca1ef7a6a96, type: 3}
  isValid: 1
  spacing: 1
