--- !u!114 &7868759559572788225
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 3251152831132408588}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "Ti th\u1EC3"
  description: "L\xE0 b\xE0o quan c\xF3 m\xE0ng k\xE9p, th\u01B0\u1EDDng d\xE0i kho\u1EA3ng
    0,5\u201310 \xB5m. M\xE0ng ngo\xE0i tr\u01A1n nh\u1EB5n, trong khi m\xE0ng trong
    g\u1EA5p n\u1EBFp t\u1EA1o nhi\u1EC1u m\xE0o (cristae), ng\u0103n ty th\u1EC3
    th\xE0nh hai khoang ri\xEAng bi\u1EC7t. Khoang ngo\xE0i n\u1EB1m gi\u1EEFa hai
    m\xE0ng, ch\u1EE9a ion H+ \u0111\xF3ng vai tr\xF2 quan tr\u1ECDng trong qu\xE1
    tr\xECnh t\u1ED5ng h\u1EE3p ATP, c\xF2n khoang trong (ch\u1EA5t n\u1EC1n) ch\u1EE9a
    nhi\u1EC1u enzyme tham gia h\xF4 h\u1EA5p t\u1EBF b\xE0o. M\xE0ng trong c\u0169ng
    mang c\xE1c ph\u1EE9c h\u1EC7 enzyme tr\u1EF1c ti\u1EBFp tham gia t\u1ED5ng h\u1EE3p
    ATP. Ngo\xE0i ra, ch\u1EA5t n\u1EC1n c\xF2n ch\u1EE9a DNA d\u1EA1ng v\xF2ng v\xE0
    ribosome, gi\xFAp ty th\u1EC3 c\xF3 kh\u1EA3 n\u0103ng t\u1EF1 nh\xE2n \u0111\xF4i
    v\xE0 t\u1ED5ng h\u1EE3p protein ri\xEAng. Nh\u1EDD c\u1EA5u tr\xFAc n\xE0y,
    ty th\u1EC3 \u0111\u01B0\u1EE3c coi l\xE0 \u201Cnh\xE0 m\xE1y n\u0103ng l\u01B0\u1EE3ng\u201D
    c\u1EE7a t\u1EBF b\xE0o, n\u01A1i di\u1EC5n ra c\xE1c qu\xE1 tr\xECnh h\xF4 h\u1EA5p
    t\u1EBF b\xE0o nh\u01B0 chu tr\xECnh Krebs, chu\u1ED7i truy\u1EC1n electron v\xE0
    t\u1ED5ng h\u1EE3p ATP.\r"
  pathType: 2
  partId: 5
