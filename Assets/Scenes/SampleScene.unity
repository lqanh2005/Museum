--- !u!114 &1269405545
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1269405543}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "L\xE0 b\xE0o quan \u0111\u1EB7c tr\u01B0ng c\u1EE7a t\u1EBF b\xE0o th\u1EF1c
    v\u1EADt v\xE0 m\u1ED9t s\u1ED1 sinh v\u1EADt nguy\xEAn sinh, c\xF3 kh\u1EA3
    n\u0103ng chuy\u1EC3n h\xF3a n\u0103ng l\u01B0\u1EE3ng \xE1nh s\xE1ng th\xE0nh
    n\u0103ng l\u01B0\u1EE3ng h\xF3a h\u1ECDc th\xF4ng qua qu\xE1 tr\xECnh quang
    h\u1EE3p. L\u1EE5c l\u1EA1p \u0111\u01B0\u1EE3c bao b\u1ECDc b\u1EDFi hai l\u1EDBp
    m\xE0ng, b\xEAn trong l\xE0 ch\u1EA5t n\u1EC1n (stroma) d\u1EA1ng d\u1ECBch keo
    ch\u1EE9a enzyme tham gia c\u1ED1 \u0111\u1ECBnh CO2, c\xF9ng v\u1EDBi c\xE1c
    ph\xE2n t\u1EED h\xF2a tan, DNA v\xE0 ribosome 70S. Trong l\u1EE5c l\u1EA1p c\xF2n
    c\xF3 h\u1EC7 th\u1ED1ng c\xE1c t\xFAi d\u1EB9t g\u1ECDi l\xE0 thylakoid, x\u1EBFp
    ch\u1ED3ng l\xEAn nhau t\u1EA1o th\xE0nh c\xE1c h\u1EA1t grana v\xE0 \u0111\u01B0\u1EE3c
    n\u1ED1i v\u1EDBi nhau b\u1EB1ng c\xE1c \u1ED1ng m\u1EA3nh. L\u1EE5c l\u1EA1p
    l\xE0 m\u1ED9t d\u1EA1ng l\u1EA1p th\u1EC3 chuy\xEAn h\xF3a, c\xF9ng h\u1ECD
    v\u1EDBi c\xE1c lo\u1EA1i l\u1EA1p th\u1EC3 kh\xE1c nh\u01B0 b\u1ED9t l\u1EA1p
    (d\u1EF1 tr\u1EEF tinh b\u1ED9t) v\xE0 s\u1EAFc l\u1EA1p (t\u1EA1o m\xE0u cho
    hoa v\xE0 qu\u1EA3). B\xE0o quan n\xE0y ch\u1EE9a s\u1EAFc t\u1ED1 chlorophyll
    gi\xFAp h\u1EA5p th\u1EE5 \xE1nh s\xE1ng v\xE0 tham gia t\u1ED5ng h\u1EE3p \u0111\u01B0\u1EDDng.
    L\u1EE5c l\u1EA1p th\u01B0\u1EDDng c\xF3 k\xEDch th\u01B0\u1EDBc kho\u1EA3ng
    2\u20134 \xB5m, ph\xE2n b\u1ED1 trong c\xE1c b\u1ED9 ph\u1EADn m\xE0u xanh c\u1EE7a
    th\u1EF1c v\u1EADt v\xE0 c\xF3 th\u1EC3 thay \u0111\u1ED5i h\xECnh d\u1EA1ng
    c\u0169ng nh\u01B0 di chuy\u1EC3n trong t\u1EBF b\xE0o. Ch\u1EE9c n\u0103ng ch\xEDnh
    c\u1EE7a l\u1EE5c l\u1EA1p l\xE0 th\u1EF1c hi\u1EC7n qu\xE1 tr\xECnh quang h\u1EE3p.\r"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d1a42da99d65ea445a6533725a130574, type: 2}
