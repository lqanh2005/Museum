--- !u!114 &8537374556164406650
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 3416409208435549028}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "T\u1EBF b\xE0o ch\u1EA5t"
  description: "L\xE0 to\xE0n b\u1ED9 v\u1EADt ch\u1EA5t s\u1ED1ng b\xEAn trong t\u1EBF
    b\xE0o, bao g\u1ED3m nh\xE2n v\xE0 t\u1EBF b\xE0o ch\u1EA5t. Trong \u0111\xF3,
    t\u1EBF b\xE0o ch\u1EA5t n\u1EB1m gi\u1EEFa m\xE0ng sinh ch\u1EA5t v\xE0 nh\xE2n,
    g\u1ED3m b\xE0o t\u01B0\u01A1ng (d\u1ECBch keo), c\xE1c b\xE0o quan v\xE0 h\u1EC7
    th\u1ED1ng b\u1ED9 khung t\u1EBF b\xE0o. B\xE0o t\u01B0\u01A1ng ch\u1EE9a ch\u1EE7
    y\u1EBFu l\xE0 n\u01B0\u1EDBc c\xF9ng v\u1EDBi c\xE1c ch\u1EA5t v\xF4 c\u01A1
    v\xE0 nhi\u1EC1u ph\xE2n t\u1EED sinh h\u1ECDc nh\u01B0 enzyme, carbohydrate
    v\xE0 axit h\u1EEFu c\u01A1. C\xE1c b\xE0o quan trong t\u1EBF b\xE0o ch\u1EA5t
    c\xF3 c\u1EA5u tr\xFAc \u0111\u1EB7c tr\u01B0ng v\xE0 \u0111\u1EA3m nhi\u1EC7m
    nh\u1EEFng ch\u1EE9c n\u0103ng ri\xEAng bi\u1EC7t. Nh\u1EDD s\u1EF1 ph\u1ED1i
    h\u1EE3p c\u1EE7a c\xE1c th\xE0nh ph\u1EA7n n\xE0y, ch\u1EA5t nguy\xEAn sinh
    tr\u1EDF th\xE0nh n\u01A1i di\u1EC5n ra h\u1EA7u h\u1EBFt c\xE1c ho\u1EA1t \u0111\u1ED9ng
    s\u1ED1ng quan tr\u1ECDng c\u1EE7a t\u1EBF b\xE0o.\r"
  pathType: 2
  partId: 3
  icon: {fileID: 21300000, guid: be2905e5883b549409132d4bdef6c760, type: 3}
