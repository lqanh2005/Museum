--- !u!114 &8934756681713488679
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 8934756681713488678}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: Lysosome
  description: "L\xE0 b\xE0o quan c\xF3 m\xE0ng, ch\u1EE9a c\xE1c enzyme th\u1EE7y
    ph\xE2n v\xE0 c\xF3 ch\u1EE9c n\u0103ng ph\xE2n gi\u1EA3i c\xE1c \u0111\u1EA1i
    ph\xE2n t\u1EED, b\xE0o quan h\u1ECFng ho\u1EB7c v\u1EADt ch\u1EA5t ngo\u1EA1i
    lai trong t\u1EBF b\xE0o. B\xE0o quan n\xE0y \u0111\u01B0\u1EE3c h\xECnh th\xE0nh
    t\u1EEB b\u1ED9 m\xE1y Golgi v\xE0 duy tr\xEC m\xF4i tr\u01B0\u1EDDng axit (kho\u1EA3ng
    pH 4,5\u20135,0) \u0111\u1EC3 ho\u1EA1t h\xF3a c\xE1c enzyme nh\u1EDD b\u01A1m
    proton (v-ATPase). Lysosome th\u01B0\u1EDDng c\xF3 k\xEDch th\u01B0\u1EDBc kho\u1EA3ng
    0,1\u20131,2 \xB5m, thay \u0111\u1ED5i t\xF9y theo tr\u1EA1ng th\xE1i v\xE0 lo\u1EA1i
    t\u1EBF b\xE0o. V\u1EC1 c\u1EA5u tr\xFAc, \u0111\xE2y l\xE0 t\xFAi m\xE0ng \u0111\u01A1n
    ch\u1EE9a nhi\u1EC1u enzyme th\u1EE7y ph\xE2n (acid hydrolases). V\u1EC1 ch\u1EE9c
    n\u0103ng, lysosome \u0111\u1EA3m nhi\u1EC7m vai tr\xF2 ti\xEAu h\xF3a n\u1ED9i
    b\xE0o, ph\xE2n h\u1EE7y c\xE1c \u0111\u1EA1i ph\xE2n t\u1EED, b\xE0o quan gi\xE0
    th\xF4ng qua qu\xE1 tr\xECnh t\u1EF1 th\u1EF1c (autophagy), c\u0169ng nh\u01B0
    x\u1EED l\xFD v\u1EADt ch\u1EA5t t\u1EEB qu\xE1 tr\xECnh th\u1EF1c b\xE0o. Ngo\xE0i
    ra, lysosome c\xF2n tham gia v\xE0o mi\u1EC5n d\u1ECBch t\u1EBF b\xE0o b\u1EB1ng
    c\xE1ch ti\xEAu di\u1EC7t vi khu\u1EA9n v\xE0 g\xF3p ph\u1EA7n v\xE0o qu\xE1
    tr\xECnh ch\u1EBFt t\u1EBF b\xE0o theo ch\u01B0\u01A1ng tr\xECnh."
  pathType: 1
  partId: 7
