--- !u!114 &9186254619523643560
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 9186254619523643559}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "Ti th\u1EC3"
  description: "L\xE0 b\xE0o quan cung c\u1EA5p n\u0103ng l\u01B0\u1EE3ng cho t\u1EBF
    b\xE0o th\xF4ng qua qu\xE1 tr\xECnh h\xF4 h\u1EA5p t\u1EBF b\xE0o hi\u1EBFu kh\xED.
    B\xE0o quan n\xE0y th\u01B0\u1EDDng c\xF3 d\u1EA1ng b\u1EA7u d\u1EE5c ho\u1EB7c
    h\xECnh que, v\u1EDBi k\xEDch th\u01B0\u1EDBc \u0111i\u1EC3n h\xECnh d\xE0i kho\u1EA3ng
    1\u201310 \xB5m v\xE0 \u0111\u01B0\u1EDDng k\xEDnh kho\u1EA3ng 0,5\u20131 \xB5m,
    \u0111\xF4i khi c\xF3 th\u1EC3 t\u1EA1o th\xE0nh m\u1EA1ng l\u01B0\u1EDBi \u1ED1ng
    trong t\u1EBF b\xE0o s\u1ED1ng. V\u1EC1 c\u1EA5u tr\xFAc, ty th\u1EC3 c\xF3 hai
    l\u1EDBp m\xE0ng: m\xE0ng ngo\xE0i tr\u01A1n nh\u1EB5n v\xE0 m\xE0ng trong g\u1EA5p
    n\u1EBFp t\u1EA1o th\xE0nh c\xE1c m\xE0o (cristae) gi\xFAp t\u0103ng di\u1EC7n
    t\xEDch b\u1EC1 m\u1EB7t. B\xEAn trong l\xE0 ch\u1EA5t n\u1EC1n (matrix) ch\u1EE9a
    c\xE1c enzyme c\u1EE7a chu\u1ED7i h\xF4 h\u1EA5p, c\xF9ng v\u1EDBi DNA ty th\u1EC3
    v\xE0 ribosome ri\xEAng. Nh\u1EDD \u0111\xF3, ty th\u1EC3 th\u1EF1c hi\u1EC7n
    ch\u1EE9c n\u0103ng ch\xEDnh l\xE0 t\u1EA1o ATP th\xF4ng qua qu\xE1 tr\xECnh
    phosphoryl h\xF3a oxy h\xF3a, \u0111\u1ED3ng th\u1EDDi tham gia v\xE0o c\xE1c
    ho\u1EA1t \u0111\u1ED9ng chuy\u1EC3n h\xF3a n\u0103ng l\u01B0\u1EE3ng, \u0111i\u1EC1u
    h\xF2a qu\xE1 tr\xECnh ch\u1EBFt t\u1EBF b\xE0o theo ch\u01B0\u01A1ng tr\xECnh
    (apoptosis) v\xE0 m\u1ED9t s\u1ED1 con \u0111\u01B0\u1EDDng truy\u1EC1n t\xEDn
    hi\u1EC7u trong t\u1EBF b\xE0o.\r"
