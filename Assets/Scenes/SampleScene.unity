--- !u!114 &7460723238915579581
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 630974990131569795}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "L\u01B0\u1EDBi n\u1ED9i ch\u1EA5t tr\u01A1n"
  description: "L\xE0 h\u1EC7 th\u1ED1ng m\xE0ng d\u1EA1ng \u1ED1ng d\u1EB9p li\xEAn
    th\xF4ng v\u1EDBi l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t h\u1EA1t, c\xF3 \xEDt ho\u1EB7c
    kh\xF4ng c\xF3 ribosome b\xE1m tr\xEAn b\u1EC1 m\u1EB7t. B\xE0o quan n\xE0y ch\u1EE9a
    nhi\u1EC1u enzyme chuy\xEAn bi\u1EC7t, tham gia v\xE0o c\xE1c qu\xE1 tr\xECnh
    sinh h\xF3a quan tr\u1ECDng c\u1EE7a t\u1EBF b\xE0o. V\u1EC1 ch\u1EE9c n\u0103ng,
    l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t tr\u01A1n \u0111\xF3ng vai tr\xF2 t\u1ED5ng
    h\u1EE3p nhi\u1EC1u lo\u1EA1i lipid nh\u01B0 phospholipid, sterol v\xE0 hormone
    sinh d\u1EE5c; tham gia chuy\u1EC3n h\xF3a \u0111\u01B0\u1EDDng, bao g\u1ED3m
    t\u1ED5ng h\u1EE3p v\xE0 ph\xE2n gi\u1EA3i glycogen gi\xFAp \u0111i\u1EC1u h\xF2a
    \u0111\u01B0\u1EDDng huy\u1EBFt; \u0111\u1ED3ng th\u1EDDi th\u1EF1c hi\u1EC7n
    ch\u1EE9c n\u0103ng kh\u1EED \u0111\u1ED9c c\xE1c ch\u1EA5t x\xE2m nh\u1EADp
    v\xE0o t\u1EBF b\xE0o. Ngo\xE0i ra, l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t tr\u01A1n
    c\xF2n l\xE0 n\u01A1i d\u1EF1 tr\u1EEF ion Ca2+, \u0111\u1EB7c bi\u1EC7t quan
    tr\u1ECDng trong c\xE1c ho\u1EA1t \u0111\u1ED9ng nh\u01B0 co c\u01A1 v\xE0 truy\u1EC1n
    t\xEDn hi\u1EC7u t\u1EBF b\xE0o, c\u0169ng nh\u01B0 tham gia t\u1ED5ng h\u1EE3p
    v\xE0 d\u1EF1 tr\u1EEF triglyceride.\r"
  pathType: 2
  partId: 13
  icon: {fileID: 21300000, guid: 1e170620a1525b14aba8de58109c6c8c, type: 3}
