--- !u!114 &5921609515011071950
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5007945331968841409}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "Nh\xE2n"
  description: "Th\u01B0\u1EDDng c\xF3 d\u1EA1ng h\xECnh c\u1EA7u v\u1EDBi \u0111\u01B0\u1EDDng
    k\xEDnh kho\u1EA3ng 5 \xB5m, \u0111\u01B0\u1EE3c bao b\u1ECDc b\u1EDFi l\u1EDBp
    m\xE0ng k\xE9p c\u1EA5u t\u1EA1o t\u1EEB phospholipid v\xE0 protein. Tr\xEAn
    m\xE0ng nh\xE2n c\xF3 nhi\u1EC1u l\u1ED7 nh\u1ECF gi\xFAp c\xE1c ch\u1EA5t c\xF3
    th\u1EC3 trao \u0111\u1ED5i gi\u1EEFa nh\xE2n v\xE0 t\u1EBF b\xE0o ch\u1EA5t.
    B\xEAn trong nh\xE2n l\xE0 ch\u1EA5t nh\xE2n (ch\u1EA5t n\u1EC1n), ch\u1EE9a
    c\xE1c s\u1EE3i nhi\u1EC5m s\u1EAFc c\xF9ng nhi\u1EC1u th\xE0nh ph\u1EA7n kh\xE1c
    nh\u01B0 enzyme, RNA v\xE0 nucleotide. S\u1EE3i nhi\u1EC5m s\u1EAFc g\u1ED3m
    DNA d\u1EA1ng xo\u1EAFn k\xE9p k\u1EBFt h\u1EE3p v\u1EDBi protein, khi t\u1EBF
    b\xE0o ph\xE2n chia s\u1EBD co ng\u1EAFn l\u1EA1i th\xE0nh nhi\u1EC5m s\u1EAFc
    th\u1EC3 v\xE0 c\xF3 th\u1EC3 quan s\xE1t d\u01B0\u1EDBi k\xEDnh hi\u1EC3n vi.
    DNA mang c\xE1c gene m\xE3 h\xF3a protein, gi\u1EEF vai tr\xF2 quan tr\u1ECDng
    trong m\u1ECDi ho\u1EA1t \u0111\u1ED9ng s\u1ED1ng c\u1EE7a t\u1EBF b\xE0o. Ngo\xE0i
    ra, trong nh\xE2n c\xF2n c\xF3 m\u1ED9t ho\u1EB7c m\u1ED9t v\xE0i h\u1EA1ch nh\xE2n
    (nh\xE2n con), l\xE0 n\u01A1i t\u1ED5ng h\u1EE3p rRNA. Nh\u1EDD c\u1EA5u tr\xFAc
    v\xE0 th\xE0nh ph\u1EA7n nh\u01B0 v\u1EADy, nh\xE2n t\u1EBF b\xE0o \u0111\xF3ng
    vai tr\xF2 l\xE0 trung t\xE2m \u0111i\u1EC1u khi\u1EC3n m\u1ECDi ho\u1EA1t \u0111\u1ED9ng
    s\u1ED1ng c\u1EE7a t\u1EBF b\xE0o.\r"
