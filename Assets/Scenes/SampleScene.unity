--- !u!114 &5862032170924693542
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2305259828919158116}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "L\u01B0\u1EDBi n\u1ED9i ch\u1EA5t h\u1EA1t"
  description: "L\xE0 h\u1EC7 th\u1ED1ng m\xE0ng n\u1ED9i b\xE0o li\xEAn k\u1EBFt
    tr\u1EF1c ti\u1EBFp v\u1EDBi m\xE0ng nh\xE2n, \u0111\xF3ng vai tr\xF2 quan tr\u1ECDng
    trong vi\u1EC7c t\u1ED5ng h\u1EE3p v\xE0 v\u1EADn chuy\u1EC3n c\xE1c ch\u1EA5t
    b\xEAn trong t\u1EBF b\xE0o. L\u01B0\u1EDBi n\u1ED9i ch\u1EA5t \u0111\u01B0\u1EE3c
    chia th\xE0nh hai lo\u1EA1i ch\xEDnh: l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t h\u1EA1t
    (rough ER) v\xE0 l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t tr\u01A1n (smooth ER). L\u01B0\u1EDBi
    n\u1ED9i ch\u1EA5t h\u1EA1t c\xF3 c\xE1c ribosome b\xE1m tr\xEAn b\u1EC1 m\u1EB7t,
    t\u1EA1o th\xE0nh m\u1EA1ng l\u01B0\u1EDBi c\xE1c t\xFAi v\xE0 \u1ED1ng d\u1EB9t
    n\u1EB1m g\u1EA7n nh\xE2n, trong khi l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t tr\u01A1n
    kh\xF4ng c\xF3 ribosome v\xE0 c\xF3 c\u1EA5u tr\xFAc d\u1EA1ng \u1ED1ng m\u1ECBn.
    V\u1EC1 ch\u1EE9c n\u0103ng, l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t h\u1EA1t ch\u1ECBu
    tr\xE1ch nhi\u1EC7m t\u1ED5ng h\u1EE3p protein, \u0111\u1EB7c bi\u1EC7t l\xE0
    c\xE1c protein d\xF9ng cho m\xE0ng t\u1EBF b\xE0o, xu\u1EA5t ti\u1EBFt ra ngo\xE0i
    ho\u1EB7c chuy\u1EC3n \u0111\u1EBFn b\u1ED9 m\xE1y Golgi v\xE0 lysosome. Trong
    khi \u0111\xF3, l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t tr\u01A1n tham gia t\u1ED5ng
    h\u1EE3p lipid, chuy\u1EC3n h\xF3a \u0111\u01B0\u1EDDng, kh\u1EED \u0111\u1ED9c
    v\xE0 d\u1EF1 tr\u1EEF ion Ca2+ \u1EDF m\u1ED9t s\u1ED1 lo\u1EA1i t\u1EBF b\xE0o."
  pathType: 1
  partId: 3
  icon: {fileID: 21300000, guid: bd83cf030539ee449a4b9ea6bff03b4f, type: 3}
