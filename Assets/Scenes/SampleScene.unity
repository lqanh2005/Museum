--- !u!114 &4902914644323800170
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2042844983729607900}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "M\xE0ng sinh ch\u1EA5t"
  description: "L\xE0 c\u1EA5u tr\xFAc \u0111\u01B0\u1EE3c t\u1EA1o b\u1EDFi l\u1EDBp
    k\xE9p phospholipid xen k\u1EBD v\u1EDBi protein, c\xF3 t\xEDnh th\u1EA5m ch\u1ECDn
    l\u1ECDc, gi\xFAp ki\u1EC3m so\xE1t s\u1EF1 di chuy\u1EC3n c\u1EE7a c\xE1c ch\u1EA5t
    v\xE0o v\xE0 ra kh\u1ECFi t\u1EBF b\xE0o. M\xE0ng c\xF3 \u0111\u1ED9 d\xE0y kho\u1EA3ng
    7\u201310 nm v\xE0 \u0111\u01B0\u1EE3c t\u1ED5 ch\u1EE9c theo m\xF4 h\xECnh \u201Ckh\u1EA3m
    l\u1ECFng\u201D (fluid mosaic), trong \u0111\xF3 c\xE1c ph\xE2n t\u1EED phospholipid
    t\u1EA1o th\xE0nh l\u1EDBp k\xE9p, c\xF2n protein c\xF3 th\u1EC3 xuy\xEAn qua
    ho\u1EB7c n\u1EB1m tr\xEAn b\u1EC1 m\u1EB7t m\xE0ng. \u1EDE m\u1EB7t ngo\xE0i,
    c\xE1c chu\u1ED7i carbohydrate g\u1EAFn v\u1EDBi protein ho\u1EB7c lipid t\u1EA1o
    th\xE0nh l\u1EDBp glycocalyx. Nh\u1EDD c\u1EA5u tr\xFAc n\xE0y, m\xE0ng sinh
    ch\u1EA5t th\u1EF1c hi\u1EC7n ch\u1EE9c n\u0103ng nh\u01B0 m\u1ED9t r\xE0o ch\u1EAFn
    b\xE1n th\u1EA5m, \u0111i\u1EC1u h\xF2a s\u1EF1 trao \u0111\u1ED5i ion v\xE0
    t\xEDn hi\u1EC7u gi\u1EEFa t\u1EBF b\xE0o v\u1EDBi m\xF4i tr\u01B0\u1EDDng, \u0111\u1ED3ng
    th\u1EDDi l\xE0 n\u01A1i g\u1EAFn k\u1EBFt c\xE1c th\u1EE5 th\u1EC3 v\xE0 tham
    gia v\xE0o c\xE1c qu\xE1 tr\xECnh v\u1EADn chuy\u1EC3n nh\u01B0 qua k\xEAnh,
    b\u01A1m, nh\u1EADp b\xE0o v\xE0 xu\u1EA5t b\xE0o.\r"
  pathType: 1
  partId: 12
  icon: {fileID: 21300000, guid: eb676e4158c80e74c8e99727c42ecba0, type: 3}
  isValid: 1
  spacing: 1
  sortFromTop: 1
