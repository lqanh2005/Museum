--- !u!114 &8502645679197768209
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7744222416600053673}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: Peroxisome
  description: "L\xE0 b\xE0o quan kh\xE1c v\u1EDBi lysosome \u1EDF ch\u1ED7 kh\xF4ng
    ch\u1EE9a enzyme th\u1EE7y ph\xE2n m\xE0 ch\u1EE7 y\u1EBFu ch\u1EE9a c\xE1c enzyme
    oxy h\xF3a. \u0110\xE2y l\xE0 nh\u1EEFng t\xFAi c\xF3 m\u1ED9t l\u1EDBp m\xE0ng
    \u0111\u01A1n, k\xEDch th\u01B0\u1EDBc th\u01B0\u1EDDng dao \u0111\u1ED9ng kho\u1EA3ng
    0,1\u20131 \xB5m t\xF9y lo\u1EA1i t\u1EBF b\xE0o. B\xEAn trong peroxisome c\xF3
    nhi\u1EC1u enzyme \u0111\u1EB7c tr\u01B0ng nh\u01B0 oxidases v\xE0 catalase,
    gi\xFAp x\u1EED l\xFD v\xE0 ph\xE2n gi\u1EA3i hydrogen peroxide (H2O2). V\u1EC1
    ch\u1EE9c n\u0103ng, peroxisome tham gia oxy h\xF3a c\xE1c ph\xE2n t\u1EED, \u0111\u1EB7c
    bi\u1EC7t l\xE0 chu\u1ED7i axit b\xE9o d\xE0i th\xF4ng qua qu\xE1 tr\xECnh beta-oxidation
    \u1EDF m\u1ED9t s\u1ED1 m\xF4, \u0111\u1ED3ng th\u1EDDi g\xF3p ph\u1EA7n ph\xE2n
    h\u1EE7y H2O2 v\xE0 tham gia v\xE0o qu\xE1 tr\xECnh sinh t\u1ED5ng h\u1EE3p m\u1ED9t
    s\u1ED1 lo\u1EA1i lipid \u0111\u1EB7c bi\u1EC7t nh\u01B0 ether phospholipids.
    Nh\u1EDD \u0111\xF3, peroxisome \u0111\xF3ng vai tr\xF2 quan tr\u1ECDng trong
    vi\u1EC7c duy tr\xEC c\xE2n b\u1EB1ng oxy h\xF3a b\xEAn trong t\u1EBF b\xE0o."
  pathType: 1
  partId: 6
  icon: {fileID: 0}
  isValid: 1
  spacing: 1
  sortFromTop: 1
  startYOffset: 0
  blinkChildren: 1
  blinkChildList:
