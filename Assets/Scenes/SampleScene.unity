--- !u!114 &7255203778668717693
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 6661350731410011013}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: Ribosomes
  description: "L\xE0 b\xE0o quan kh\xF4ng c\xF3 m\xE0ng bao b\u1ECDc, c\xF3 d\u1EA1ng
    h\xECnh c\u1EA7u v\u1EDBi \u0111\u01B0\u1EDDng k\xEDnh kho\u1EA3ng 150 A. Th\xE0nh
    ph\u1EA7n h\xF3a h\u1ECDc c\u1EE7a ribosome g\u1ED3m rRNA chi\u1EBFm kho\u1EA3ng
    80\u201390% v\xE0 protein. M\u1ED7i ribosome \u0111\u01B0\u1EE3c c\u1EA5u t\u1EA1o
    t\u1EEB hai ti\u1EC3u \u0111\u01A1n v\u1ECB c\xF3 k\xEDch th\u01B0\u1EDBc kh\xE1c
    nhau: ti\u1EC3u ph\u1EA7n l\u1EDBn (60S) v\xE0 ti\u1EC3u ph\u1EA7n nh\u1ECF (40S).
    Ribosome c\xF3 th\u1EC3 g\u1EAFn tr\xEAn m\xE0ng nh\xE2n, l\u01B0\u1EDBi n\u1ED9i
    ch\u1EA5t h\u1EA1t ho\u1EB7c t\u1ED3n t\u1EA1i t\u1EF1 do trong t\u1EBF b\xE0o
    ch\u1EA5t, v\xE0 c\u0169ng c\xF3 m\u1EB7t trong ty th\u1EC3 v\xE0 l\u1EE5c l\u1EA1p.
    Ch\u1EE9c n\u0103ng ch\xEDnh c\u1EE7a ribosome l\xE0 l\xE0m b\u1ED9 m\xE1y t\u1ED5ng
    h\u1EE3p protein cho t\u1EBF b\xE0o. \u1EDE nh\u1EEFng t\u1EBF b\xE0o c\xF3 ho\u1EA1t
    \u0111\u1ED9ng t\u1ED5ng h\u1EE3p protein m\u1EA1nh, s\u1ED1 l\u01B0\u1EE3ng
    ribosome c\xF3 th\u1EC3 l\xEAn t\u1EDBi h\xE0ng tri\u1EC7u, ch\u1EB3ng h\u1EA1n
    nh\u01B0 trong c\xE1c t\u1EBF b\xE0o tuy\u1EBFn t\u1EE5y \u1EDF ng\u01B0\u1EDDi.\r"
  pathType: 2
  partId: 9
  icon: {fileID: 21300000, guid: 3f5fadacd7aa2794c80dbc71aae792a9, type: 3}
  isValid: 1
  spacing: 1
