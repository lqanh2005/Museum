--- !u!114 &7826312049725819405
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7789246259571461944}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "Nh\xE2n"
  description: "L\xE0 b\xE0o quan ch\u1EE9a v\u1EADt ch\u1EA5t di truy\u1EC1n (DNA)
    v\xE0 \u0111\xF3ng vai tr\xF2 \u0111i\u1EC1u khi\u1EC3n m\u1ECDi ho\u1EA1t \u0111\u1ED9ng
    s\u1ED1ng c\u1EE7a t\u1EBF b\xE0o th\xF4ng qua vi\u1EC7c \u0111i\u1EC1u h\xF2a
    t\u1ED5ng h\u1EE3p protein. Nh\xE2n th\u01B0\u1EDDng c\xF3 k\xEDch th\u01B0\u1EDBc
    kho\u1EA3ng 5\u201310 \xB5m (t\xF9y lo\u1EA1i t\u1EBF b\xE0o) v\xE0 c\xF3 h\xECnh
    d\u1EA1ng c\u1EA7u ho\u1EB7c b\u1EA7u d\u1EE5c. C\u1EA5u tr\xFAc c\u1EE7a nh\xE2n
    \u0111\u01B0\u1EE3c bao b\u1ECDc b\u1EDFi m\xE0ng nh\xE2n g\u1ED3m hai l\u1EDBp
    m\xE0ng li\xEAn t\u1EE5c v\u1EDBi l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t, tr\xEAn
    \u0111\xF3 c\xF3 c\xE1c l\u1ED7 nh\xE2n gi\xFAp trao \u0111\u1ED5i ph\xE2n t\u1EED
    v\u1EDBi b\xE0o t\u01B0\u01A1ng. B\xEAn trong nh\xE2n ch\u1EE9a nhi\u1EC5m s\u1EAFc
    ch\u1EA5t (g\u1ED3m DNA v\xE0 protein) c\xF9ng v\u1EDBi h\u1EA1ch nh\xE2n, n\u01A1i
    di\u1EC5n ra qu\xE1 tr\xECnh t\u1ED5ng h\u1EE3p rRNA v\xE0 l\u1EAFp r\xE1p c\xE1c
    ti\u1EC3u ph\u1EA7n ribosome. Nh\xE2n c\xF3 ch\u1EE9c n\u0103ng l\u01B0u gi\u1EEF
    v\u1EADt li\u1EC7u di truy\u1EC1n, \u0111i\u1EC1u khi\u1EC3n bi\u1EC3u hi\u1EC7n
    gen th\xF4ng qua phi\xEAn m\xE3, tham gia sao ch\xE9p DNA v\xE0 t\u1ED5 ch\u1EE9c
    c\xE1c ho\u1EA1t \u0111\u1ED9ng sinh h\u1ECDc li\xEAn quan \u0111\u1EBFn di truy\u1EC1n.\r"
  pathType: 1
  partId: 1
  icon: {fileID: 21300000, guid: ef2246ee455dda147aec85a9d31d5d0a, type: 3}
  isValid: 1
