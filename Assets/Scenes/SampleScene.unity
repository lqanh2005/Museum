  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "Th\xE0nh t\u1EBF b\xE0o"
  description: "Bao b\xEAn ngo\xE0i m\xE0ng t\u1EBF b\xE0o l\xE0 th\xE0nh t\u1EBF
    b\xE0o t\u1EA1o h\xECnh d\u1EA1ng v\xE0 s\u1EF1 c\u1EE9ng ch\u1EAFc c\u1EE7a
    t\u1EBF b\xE0o ch\u1ED1ng l\u1EA1i \xE1p l\u1EF1c c\u1EE7a n\u01B0\u1EDBc \u0111i
    v\xE0o t\u1EBF b\xE0o v\xE0 s\u1EF1 g\xE2y h\u1EA1i c\u1EE7a c\xE1c sinh v\u1EADt
    hay t\u1EBF b\xE0o kh\xE1c. \u0110\u01B0\u1EE3c c\u1EA5u t\u1EA1o b\u1EDFi peptidoglycan
    (bao g\u1ED3m c\xE1c chu\u1ED7i carbohydrate li\xEAn k\u1EBFt v\u1EDBi peptide).
    Tu\u1EF3 theo c\u1EA5u tr\xFAc v\xE0 th\xE0nh ph\u1EA7n ho\xE1 h\u1ECDc c\u1EE7a
    l\u1EDBp peptidoglycan, vi khu\u1EA9n \u0111\u01B0\u1EE3c chia th\xE0nh hai lo\u1EA1i:
    Gram d\u01B0\u01A1ng (Gr+) v\xE0 Gram \xE2m (Gr\u2013). "
  pathType: 0
  partId: 4
  icon: {fileID: 21300000, guid: ff90b1d89d09a3c4d835b375a6b64e66, type: 3}
  isValid: 1
