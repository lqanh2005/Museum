--- !u!114 &7694589254447696998
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7694589254447696997}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "M\xE0ng sinh ch\u1EA5t"
  description: "L\xE0 l\u1EDBp bao b\u1ECDc t\u1EBF b\xE0o, \u0111\u01B0\u1EE3c c\u1EA5u
    t\u1EA1o t\u1EEB l\u1EDBp k\xE9p phospholipid xen k\u1EBD v\u1EDBi protein, b\u1EA3o
    v\u1EC7 v\xE0 ng\u0103n c\xE1ch ph\u1EA7n b\xEAn trong t\u1EBF b\xE0o v\u1EDBi
    m\xF4i tr\u01B0\u1EDDng ngo\u1EA1i b\xE0o. C\u1EA5u tr\xFAc c\u1EE7a m\xE0ng
    theo m\xF4 h\xECnh \u201Ckh\u1EA3m l\u1ECFng\u201D (fluid mosaic), trong \u0111\xF3
    c\xE1c ph\xE2n t\u1EED phospholipid c\xF3 \u0111u\xF4i k\u1EF5 n\u01B0\u1EDBc
    quay v\xE0o nhau \u1EDF gi\u1EEFa hai l\u1EDBp, c\xF2n c\xE1c \u0111\u1EA7u \u01B0a
    n\u01B0\u1EDBc h\u01B0\u1EDBng ra ngo\xE0i ho\u1EB7c v\xE0o ph\xEDa trong m\xE0ng
    ti\u1EBFp x\xFAc v\u1EDBi m\xF4i tr\u01B0\u1EDDng n\u01B0\u1EDBc. Protein tr\xEAn
    m\xE0ng c\xF3 th\u1EC3 xuy\xEAn qua l\u1EDBp lipid (protein xuy\xEAn m\xE0ng)
    ho\u1EB7c b\xE1m v\xE0o b\u1EC1 m\u1EB7t m\xE0ng (protein b\xE1m m\xE0ng), th\u1EF1c
    hi\u1EC7n nhi\u1EC1u ch\u1EE9c n\u0103ng kh\xE1c nhau. Nh\u1EDD c\u1EA5u tr\xFAc
    n\xE0y, m\xE0ng sinh ch\u1EA5t ki\u1EC3m so\xE1t s\u1EF1 v\u1EADn chuy\u1EC3n
    c\xE1c ch\u1EA5t \u0111i v\xE0o v\xE0 ra kh\u1ECFi t\u1EBF b\xE0o, \u0111\u1ED3ng
    th\u1EDDi \u0111\xF3ng vai tr\xF2 quan tr\u1ECDng trong t\u01B0\u01A1ng t\xE1c
    v\xE0 truy\u1EC1n th\xF4ng tin gi\u1EEFa c\xE1c t\u1EBF b\xE0o.\r"
  pathType: 2
  partId: 2
