--- !u!114 &5845925473740355643
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5845925473740355642}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "Kh\xF4ng b\xE0o"
  description: "L\xE0 b\xE0o quan c\xF3 m\xE0ng bao b\u1ECDc, th\u01B0\u1EDDng c\xF3
    k\xEDch th\u01B0\u1EDBc l\u1EDBn v\xE0 t\u1ED3n t\u1EA1i l\xE2u d\xE0i trong
    t\u1EBF b\xE0o, \u0111\u1EB7c bi\u1EC7t l\xE0 kh\xF4ng b\xE0o trung t\xE2m \u1EDF
    t\u1EBF b\xE0o th\u1EF1c v\u1EADt \u2013 m\u1ED9t khoang linh \u0111\u1ED9ng
    ch\u1EE9a ch\u1EE7 y\u1EBFu l\xE0 n\u01B0\u1EDBc. Kh\xF4ng b\xE0o c\xF3 th\u1EC3
    ch\u1EE9a nhi\u1EC1u lo\u1EA1i ch\u1EA5t kh\xE1c nhau: \u1EDF m\u1ED9t s\u1ED1
    t\u1EBF b\xE0o c\u1EE7a l\xE1, hoa v\xE0 qu\u1EA3, ch\xFAng ch\u1EE9a c\xE1c
    s\u1EAFc t\u1ED1 gi\xFAp thu h\xFAt c\xF4n tr\xF9ng th\u1EE5 ph\u1EA5n ho\u1EB7c
    \u0111\u1ED9ng v\u1EADt \u0111\u1EBFn \u0103n v\xE0 ph\xE1t t\xE1n h\u1EA1t;
    \u1EDF c\xE1c tr\u01B0\u1EDDng h\u1EE3p kh\xE1c, kh\xF4ng b\xE0o \u0111\xF3ng
    vai tr\xF2 l\xE0 n\u01A1i d\u1EF1 tr\u1EEF carbohydrate, ion, mu\u1ED1i kho\xE1ng,
    ch\u1EA5t th\u1EA3i, c\u0169ng nh\u01B0 c\xE1c enzyme th\u1EE7y ph\xE2n v\xE0
    enzyme kh\u1EED \u0111\u1ED9c. V\xED d\u1EE5, qu\u1EA3 chanh c\xF3 v\u1ECB chua
    do kh\xF4ng b\xE0o ch\u1EE9a nhi\u1EC1u axit citric. V\u1EC1 ch\u1EE9c n\u0103ng,
    kh\xF4ng b\xE0o gi\xFAp \u0111i\u1EC1u h\xF2a \xE1p su\u1EA5t th\u1EA9m th\u1EA5u
    c\u1EE7a t\u1EBF b\xE0o, \u0111\u1ED3ng th\u1EDDi tham gia d\u1EF1 tr\u1EEF c\xE1c
    ch\u1EA5t nh\u01B0 protein, \u0111\u01B0\u1EDDng, axit h\u1EEFu c\u01A1, mu\u1ED1i
    kho\xE1ng ho\u1EB7c ch\u1EE9a c\xE1c ch\u1EA5t th\u1EA3i v\xE0 s\u1EAFc t\u1ED1
    nh\u01B0 \u0111\u1ECF, t\xEDm, xanh d\u01B0\u01A1ng.\r"
  pathType: 2
  partId: 6
  icon: {fileID: 21300000, guid: 5be36c840788dd0409a6a7741c09b06f, type: 3}
  isValid: 1
  spacing: 1
