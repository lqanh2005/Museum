--- !u!114 &9165011289161979637
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5154293930469358292}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "B\u1ED9 m\xE1y Golgi"
  description: "L\xE0 b\xE0o quan g\u1ED3m c\xE1c t\xFAi d\u1EB9p x\u1EBFp song song
    nh\u01B0ng t\xE1ch r\u1EDDi nhau, t\u1EA1o n\xEAn m\u1ED9t c\u1EA5u tr\xFAc c\xF3
    t\xEDnh ph\xE2n c\u1EF1c r\xF5 r\u1EC7t v\u1EDBi m\u1EB7t nh\u1EADp (m\u1EB7t
    cis) v\xE0 m\u1EB7t xu\u1EA5t (m\u1EB7t trans). M\u1EB7t cis c\xF3 ch\u1EE9c
    n\u0103ng ti\u1EBFp nh\u1EADn c\xE1c s\u1EA3n ph\u1EA9m t\u1EEB l\u01B0\u1EDBi
    n\u1ED9i ch\u1EA5t, trong khi m\u1EB7t trans \u0111\u1EA3m nhi\u1EC7m vi\u1EC7c
    ph\xE2n ph\u1ED1i ch\xFAng \u0111\u1EBFn c\xE1c v\u1ECB tr\xED kh\xE1c trong
    t\u1EBF b\xE0o ho\u1EB7c ra ngo\xE0i. Trong qu\xE1 tr\xECnh ho\u1EA1t \u0111\u1ED9ng,
    c\xE1c s\u1EA3n ph\u1EA9m \u0111\u01B0\u1EE3c v\u1EADn chuy\u1EC3n t\u1EEB m\u1EB7t
    nh\u1EADp \u0111\u1EBFn m\u1EB7t xu\u1EA5t th\xF4ng qua c\xE1c t\xFAi v\u1EADn
    chuy\u1EC3n. B\u1ED9 m\xE1y Golgi c\xF3 ch\u1EE9c n\u0103ng ch\xEDnh l\xE0 s\u1EEDa
    \u0111\u1ED5i, ph\xE2n lo\u1EA1i, \u0111\xF3ng g\xF3i v\xE0 v\u1EADn chuy\u1EC3n
    c\xE1c protein v\xE0 lipid do l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t t\u1ED5ng h\u1EE3p.
    Ngo\xE0i ra, n\xF3 c\xF2n tham gia t\u1ED5ng h\u1EE3p m\u1ED9t s\u1ED1 polysaccharide
    c\u1EE7a th\xE0nh t\u1EBF b\xE0o (tr\u1EEB cellulose) v\xE0 g\xF3p ph\u1EA7n
    t\u1EA1o n\xEAn ch\u1EA5t n\u1EC1n ngo\u1EA1i b\xE0o.\r"
  pathType: 2
  partId: 11
  icon: {fileID: 21300000, guid: 682f7ff46ed90684cb4f899d499eb809, type: 3}
  isValid: 1
  spacing: 1
