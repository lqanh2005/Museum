--- !u!114 &7999396485568570235
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 7999396485568570234}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "Th\xE0nh t\u1EBF b\xE0o"
  description: "L\xE0 l\u1EDBp bao b\u1ECDc b\xEAn ngo\xE0i m\xE0ng sinh ch\u1EA5t,
    ch\u1EC9 c\xF3 \u1EDF t\u1EBF b\xE0o th\u1EF1c v\u1EADt v\xE0 n\u1EA5m. \u1EDE
    th\u1EF1c v\u1EADt, th\xE0nh t\u1EBF b\xE0o \u0111\u01B0\u1EE3c c\u1EA5u t\u1EA1o
    ch\u1EE7 y\u1EBFu t\u1EEB c\xE1c b\xF3 s\u1EE3i cellulose c\u1EE9ng ch\u1EAFc,
    c\xF9ng v\u1EDBi pectin v\xE0 protein, trong khi \u1EDF n\u1EA5m, th\xE0nh t\u1EBF
    b\xE0o ch\u1EE7 y\u1EBFu ch\u1EE9a chitin. Gi\u1EEFa th\xE0nh c\u1EE7a hai t\u1EBF
    b\xE0o k\u1EC1 nhau c\xF3 phi\u1EBFn gi\u1EEFa, \u0111\u01B0\u1EE3c t\u1EA1o
    t\u1EEB polysaccharide, gi\xFAp li\xEAn k\u1EBFt c\xE1c t\u1EBF b\xE0o v\u1EDBi
    nhau t\u01B0\u01A1ng t\u1EF1 nh\u01B0 ch\u1EA5t n\u1EC1n ngo\u1EA1i b\xE0o \u1EDF
    \u0111\u1ED9ng v\u1EADt. Ngo\xE0i ra, c\xE1c t\u1EBF b\xE0o c\xF2n c\xF3 c\u1EA7u
    sinh ch\u1EA5t, h\u1ED7 tr\u1EE3 trao \u0111\u1ED5i ch\u1EA5t gi\u1EEFa c\xE1c
    t\u1EBF b\xE0o. Nh\u1EDD c\u1EA5u tr\xFAc n\xE0y, th\xE0nh t\u1EBF b\xE0o c\xF3
    ch\u1EE9c n\u0103ng b\u1EA3o v\u1EC7, duy tr\xEC h\xECnh d\u1EA1ng \u1ED5n \u0111\u1ECBnh
    v\xE0 \u0111i\u1EC1u ch\u1EC9nh l\u01B0\u1EE3ng n\u01B0\u1EDBc ra v\xE0o t\u1EBF
    b\xE0o.\r"
  pathType: 2
  partId: 1
  icon: {fileID: 21300000, guid: 3d91d94e56d0f264286ca474d0676048, type: 3}
  isValid: 1
  spacing: 1
  sortFromTop: 1
  startYOffset: 0
