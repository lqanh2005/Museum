--- !u!114 &2620028599920269285
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1731243058011585029}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: Ribosomes
  description: "L\xE0 b\xE0o quan kh\xF4ng c\xF3 m\xE0ng, \u0111\xF3ng vai tr\xF2
    l\xE0 n\u01A1i di\u1EC5n ra qu\xE1 tr\xECnh t\u1ED5ng h\u1EE3p protein trong
    t\u1EBF b\xE0o. \u1EDE sinh v\u1EADt nh\xE2n th\u1EF1c, ribosome c\xF3 k\xEDch
    th\u01B0\u1EDBc kho\u1EA3ng 25\u201330 nm, thu\u1ED9c lo\u1EA1i 80S v\xE0 \u0111\u01B0\u1EE3c
    c\u1EA5u t\u1EA1o t\u1EEB hai ti\u1EC3u \u0111\u01A1n v\u1ECB l\xE0 40S v\xE0
    60S. V\u1EC1 c\u1EA5u tr\xFAc, ribosome g\u1ED3m rRNA v\xE0 protein, c\xF3 th\u1EC3
    t\u1ED3n t\u1EA1i t\u1EF1 do trong t\u1EBF b\xE0o ch\u1EA5t ho\u1EB7c g\u1EAFn
    tr\xEAn b\u1EC1 m\u1EB7t l\u01B0\u1EDBi n\u1ED9i ch\u1EA5t h\u1EA1t. Trong qu\xE1
    tr\xECnh ho\u1EA1t \u0111\u1ED9ng, ti\u1EC3u \u0111\u01A1n v\u1ECB nh\u1ECF \u0111\u1EA3m
    nhi\u1EC7m vi\u1EC7c gi\u1EA3i m\xE3 mRNA, c\xF2n ti\u1EC3u \u0111\u01A1n v\u1ECB
    l\u1EDBn th\u1EF1c hi\u1EC7n ho\u1EA1t t\xEDnh peptidyl-transferase \u0111\u1EC3
    li\xEAn k\u1EBFt c\xE1c axit amin t\u1EA1o th\xE0nh chu\u1ED7i polypeptide. Nh\u1EDD
    \u0111\xF3, ribosome th\u1EF1c hi\u1EC7n ch\u1EE9c n\u0103ng ch\xEDnh l\xE0 d\u1ECBch
    m\xE3 th\xF4ng tin di truy\u1EC1n t\u1EEB mRNA th\xE0nh protein. S\u1ED1 l\u01B0\u1EE3ng
    ribosome trong t\u1EBF b\xE0o r\u1EA5t l\u1EDBn, c\xF3 th\u1EC3 l\xEAn t\u1EDBi
    h\xE0ng tri\u1EC7u \u1EDF nh\u1EEFng t\u1EBF b\xE0o c\xF3 ho\u1EA1t \u0111\u1ED9ng
    t\u1ED5ng h\u1EE3p m\u1EA1nh.\r"
  pathType: 1
  partId: 2
