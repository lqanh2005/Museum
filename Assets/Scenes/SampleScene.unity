--- !u!114 &8814367200388537886
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 4083834263955495207}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7ed892f9d2e438e42ae2ec9c9030c81e, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  title: "Trung th\u1EC3"
  description: "L\xE0 trung t\xE2m t\u1ED5 ch\u1EE9c vi \u1ED1ng c\u1EE7a t\u1EBF
    b\xE0o, \u0111\xF3ng vai tr\xF2 quan tr\u1ECDng trong vi\u1EC7c h\xECnh th\xE0nh
    thoi ph\xE2n b\xE0o trong qu\xE1 tr\xECnh ph\xE2n chia t\u1EBF b\xE0o. \u1EDE
    t\u1EBF b\xE0o \u0111\u1ED9ng v\u1EADt, trung th\u1EC3 g\u1ED3m hai trung t\u1EED
    (centrioles) x\u1EBFp vu\xF4ng g\xF3c v\u1EDBi nhau v\xE0 \u0111\u01B0\u1EE3c
    bao quanh b\u1EDFi ch\u1EA5t quanh trung t\u1EED (pericentriolar material \u2013
    PCM). M\u1ED7i trung t\u1EED c\xF3 c\u1EA5u tr\xFAc g\u1ED3m 9 b\u1ED9 ba vi
    \u1ED1ng (triplet microtubules) v\xE0 c\xF3 k\xEDch th\u01B0\u1EDBc \u0111i\u1EC3n
    h\xECnh kho\u1EA3ng 0,5 \xB5m chi\u1EC1u d\xE0i v\xE0 0,2 \xB5m \u0111\u01B0\u1EDDng
    k\xEDnh. Trung th\u1EC3 ho\u1EA1t \u0111\u1ED9ng nh\u01B0 m\u1ED9t trung t\xE2m
    t\u1ED5 ch\u1EE9c vi \u1ED1ng (MTOC), gi\xFAp ph\xE1t sinh v\xE0 s\u1EAFp x\u1EBFp
    c\xE1c vi \u1ED1ng, t\u1EEB \u0111\xF3 t\u1ED5 ch\u1EE9c thoi ph\xE2n b\xE0o,
    \u0111\u1ECBnh h\u01B0\u1EDBng tr\u1EE5c ph\xE2n chia v\xE0 g\xF3p ph\u1EA7n
    duy tr\xEC c\u1EA5u tr\xFAc b\u1ED9 khung t\u1EBF b\xE0o.\r"
  pathType: 1
  partId: 4
  icon: {fileID: 21300000, guid: 9c1cfc78c69e3174f85a701e61fe0837, type: 3}
  isValid: 1
  spacing: 1
  sortFromTop: 1
  startYOffset: 0
